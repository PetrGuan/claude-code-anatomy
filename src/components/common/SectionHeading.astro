---
interface Props {
  id: string;
  title: string;
  subtitle?: string;
}

const { id, title, subtitle } = Astro.props;
---

<div id={id} class="scroll-mt-24 mb-8 group">
  <h2 class="text-2xl font-bold text-text">
    <a href={`#${id}`} class="hover:text-accent-purple transition-colors">
      {title}
      <span class="opacity-0 group-hover:opacity-100 transition-opacity text-text-secondary ml-2 text-lg">#</span>
    </a>
  </h2>
  {subtitle && <p class="mt-2 text-text-secondary">{subtitle}</p>}
</div>
