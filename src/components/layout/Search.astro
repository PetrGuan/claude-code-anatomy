---
import type { Locale } from "../../i18n/locales";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const placeholder = locale === "zh" ? "搜索..." : "Search...";
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!-- Search trigger button -->
<button
  id="search-trigger"
  class="p-2 text-text-secondary hover:text-text transition-colors"
  aria-label={locale === "zh" ? "搜索" : "Search"}
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
  </svg>
</button>

<!-- Search modal overlay -->
<div id="search-modal" class="fixed inset-0 z-[100] hidden" role="dialog" aria-modal="true" aria-label="Search">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>

  <!-- Dialog -->
  <div class="relative mx-auto mt-20 max-w-2xl px-4">
    <div class="rounded-xl border border-bg-border bg-bg shadow-2xl overflow-hidden">
      <div id="pagefind-container" class="pagefind-ui-container"></div>
    </div>
  </div>
</div>

<style is:global>
  /* Pagefind UI theme-aware overrides using CSS variables */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: rgb(var(--color-accent-purple));
    --pagefind-ui-text: rgb(var(--color-text));
    --pagefind-ui-background: rgb(var(--color-bg));
    --pagefind-ui-border: rgb(var(--color-bg-border));
    --pagefind-ui-tag: rgb(var(--color-bg-card));
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 8px;
    --pagefind-ui-image-border-radius: 8px;
    --pagefind-ui-image-box-ratio: 0;
    --pagefind-ui-font: 'Inter', system-ui, sans-serif;
  }

  .pagefind-ui .pagefind-ui__search-input {
    background: rgb(var(--color-bg-card)) !important;
    color: rgb(var(--color-text)) !important;
    border-color: rgb(var(--color-bg-border)) !important;
    font-family: 'Inter', system-ui, sans-serif !important;
    padding: 12px 16px !important;
    font-size: 16px !important;
  }

  .pagefind-ui .pagefind-ui__search-input::placeholder {
    color: rgb(var(--color-text-secondary)) !important;
  }

  .pagefind-ui .pagefind-ui__search-input:focus {
    border-color: rgb(var(--color-accent-purple)) !important;
    outline: none !important;
    box-shadow: 0 0 0 2px rgb(var(--color-accent-purple) / 0.2) !important;
  }

  .pagefind-ui .pagefind-ui__result {
    border-color: rgb(var(--color-bg-border)) !important;
    padding: 12px 0 !important;
  }

  .pagefind-ui .pagefind-ui__result-link {
    color: rgb(var(--color-accent-purple)) !important;
    font-weight: 500 !important;
  }

  .pagefind-ui .pagefind-ui__result-link:hover {
    text-decoration: underline !important;
  }

  .pagefind-ui .pagefind-ui__result-excerpt {
    color: rgb(var(--color-text-secondary)) !important;
  }

  .pagefind-ui mark {
    background: rgb(var(--color-accent-purple) / 0.3) !important;
    color: rgb(var(--color-text)) !important;
    border-radius: 2px !important;
    padding: 0 2px !important;
  }

  .pagefind-ui .pagefind-ui__message {
    color: rgb(var(--color-text-secondary)) !important;
  }

  .pagefind-ui .pagefind-ui__search-clear {
    color: rgb(var(--color-text-secondary)) !important;
    background: transparent !important;
  }

  .pagefind-ui .pagefind-ui__button {
    background: rgb(var(--color-bg-card)) !important;
    color: rgb(var(--color-text)) !important;
    border-color: rgb(var(--color-bg-border)) !important;
  }

  .pagefind-ui .pagefind-ui__button:hover {
    border-color: rgb(var(--color-accent-purple)) !important;
  }
</style>

<script define:vars={{ placeholder, base }}>
  // Initialize Pagefind UI when search is opened
  let pagefindLoaded = false;

  function openSearch() {
    document.getElementById('search-modal')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    if (!pagefindLoaded) {
      // Dynamically load Pagefind UI
      const link = document.createElement('link');
      link.rel = 'stylesheet';
      link.href = base + '/pagefind/pagefind-ui.css';
      document.head.appendChild(link);

      const script = document.createElement('script');
      script.src = base + '/pagefind/pagefind-ui.js';
      script.onload = () => {
        pagefindLoaded = true;
        new window.PagefindUI({
          element: '#pagefind-container',
          showSubResults: true,
          showImages: false,
          placeholder: placeholder,
          baseUrl: base + '/',
        });
        // Auto-focus the search input
        setTimeout(() => {
          document.querySelector('.pagefind-ui__search-input')?.focus();
        }, 100);
      };
      script.onerror = () => {
        pagefindLoaded = false;
        const container = document.getElementById('pagefind-container');
        if (container) container.innerHTML = '<p style="padding:16px;color:#8888a0;text-align:center">Search failed to load. Please try again.</p>';
      };
      document.head.appendChild(script);
    } else {
      // Focus existing input
      setTimeout(() => {
        document.querySelector('.pagefind-ui__search-input')?.focus();
      }, 50);
    }
  }

  function closeSearch() {
    document.getElementById('search-modal')?.classList.add('hidden');
    document.body.style.overflow = '';
    document.getElementById('search-trigger')?.focus();
  }

  // Trigger button
  document.getElementById('search-trigger')?.addEventListener('click', openSearch);

  // Close on backdrop click
  document.getElementById('search-backdrop')?.addEventListener('click', closeSearch);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (!document.getElementById('search-modal')?.classList.contains('hidden')) {
        closeSearch();
      }
    }
    // Cmd+K / Ctrl+K to open
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      const modal = document.getElementById('search-modal');
      if (modal?.classList.contains('hidden')) {
        openSearch();
      } else {
        closeSearch();
      }
    }
  });

  // Focus trap
  document.getElementById('search-modal')?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const modal = document.getElementById('search-modal');
    if (!modal || modal.classList.contains('hidden')) return;
    const focusable = modal.querySelectorAll('input, button, a, [tabindex]:not([tabindex="-1"])');
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });
</script>
