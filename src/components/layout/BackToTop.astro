---
import type { Locale } from "../../i18n/locales";
interface Props { locale?: Locale; }
const { locale = "en" } = Astro.props;
---

<button
  id="back-to-top"
  class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full bg-bg-card border border-bg-border text-text-secondary hover:text-accent-purple hover:border-accent-purple shadow-lg transition-all duration-200 opacity-0 translate-y-4 pointer-events-none flex items-center justify-center"
  aria-label={locale === "zh" ? "返回顶部" : "Back to top"}
>
  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top');
  function toggleBtn() {
    if (!btn) return;
    if (window.scrollY > 400) {
      btn.classList.remove('opacity-0', 'translate-y-4', 'pointer-events-none');
      btn.classList.add('opacity-100', 'translate-y-0', 'pointer-events-auto');
    } else {
      btn.classList.add('opacity-0', 'translate-y-4', 'pointer-events-none');
      btn.classList.remove('opacity-100', 'translate-y-0', 'pointer-events-auto');
    }
  }
  window.addEventListener('scroll', toggleBtn, { passive: true });
  btn?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
</script>
