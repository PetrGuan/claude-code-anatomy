---
import type { Locale } from "../../i18n/locales";
import { t } from "../../i18n/translations";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
---

<footer class="border-t border-bg-border mt-32 py-12">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-secondary">
      <p>
        {t(locale, "footer.description")}
      </p>
      <div class="flex items-center gap-4">
        <span>{t(locale, "footer.basedOn")}</span>
        <span>·</span>
        <span>{locale === "zh" ? "1,902 个文件 · 512K+ 行代码" : "1,902 files · 512K+ LOC"}</span>
      </div>
    </div>
  </div>
</footer>
