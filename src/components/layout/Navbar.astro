---
import type { Locale } from "../../i18n/locales";
import { getLocalePath, getAlternatePath } from "../../i18n/locales";
import { t } from "../../i18n/translations";
import Search from "./Search.astro";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;

const navItems = [
  { path: "/", key: "nav.home", group: "core" },
  { path: "/overview", key: "nav.overview", group: "core" },
  { path: "/query-pipeline", key: "nav.queryPipeline", group: "core" },
  { path: "/tool-system", key: "nav.toolSystem", group: "core" },
  { path: "/permission-security", key: "nav.permissionSecurity", group: "core" },
  { path: "/terminal-ui", key: "nav.terminalUI", group: "advanced" },
  { path: "/plugin-skill", key: "nav.pluginSkill", group: "advanced" },
  { path: "/message-compaction", key: "nav.messageCompaction", group: "advanced" },
  { path: "/agent-system", key: "nav.agentSystem", group: "advanced" },
  { path: "/ide-bridge", key: "nav.ideBridge", group: "optional" },
  { path: "/mcp-integration", key: "nav.mcpIntegration", group: "optional" },
];

const groups = ["core", "advanced", "optional"] as const;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname.replace(base, '') || '/';

const alternatePath = getAlternatePath(locale, Astro.url.pathname);
const alternateLinkLabel = locale === "en" ? "中文" : "EN";
---

<nav class="fixed top-0 left-0 right-0 z-50 border-b border-bg-border bg-bg/80 backdrop-blur-xl">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">
      <a href={getLocalePath(locale, "/")} class="flex items-center gap-2 font-mono text-sm font-bold text-accent-purple">
        <span class="text-lg">∧</span>
        Claude Code Anatomy
      </a>
      <div class="hidden lg:flex items-center gap-0.5">
        {navItems.filter(i => i.group === "core").map((item) => (
          <a
            href={getLocalePath(locale, item.path)}
            class:list={[
              "px-2 py-1.5 rounded-lg text-xs transition-colors whitespace-nowrap",
              currentPath === item.path
                ? "bg-accent-purple/10 text-accent-purple"
                : "text-text-secondary hover:text-text hover:bg-bg-card",
            ]}
          >
            {t(locale, item.key)}
          </a>
        ))}
        <span class="mx-1 text-bg-border">|</span>
        {navItems.filter(i => i.group === "advanced").map((item) => (
          <a
            href={getLocalePath(locale, item.path)}
            class:list={[
              "px-2 py-1.5 rounded-lg text-xs transition-colors whitespace-nowrap",
              currentPath === item.path
                ? "bg-accent-purple/10 text-accent-purple"
                : "text-text-secondary hover:text-text hover:bg-bg-card",
            ]}
          >
            {t(locale, item.key)}
          </a>
        ))}
        <span class="mx-1 text-bg-border">|</span>
        {navItems.filter(i => i.group === "optional").map((item) => (
          <a
            href={getLocalePath(locale, item.path)}
            class:list={[
              "px-2 py-1.5 rounded-lg text-xs transition-colors whitespace-nowrap",
              currentPath === item.path
                ? "bg-accent-purple/10 text-accent-purple"
                : "text-text-secondary hover:text-text hover:bg-bg-card",
            ]}
          >
            {t(locale, item.key)}
          </a>
        ))}
        <a
          href={alternatePath}
          class="ml-1 px-2 py-1.5 rounded-lg text-xs transition-colors text-text-secondary hover:text-text hover:bg-bg-card border border-bg-border whitespace-nowrap"
        >
          {alternateLinkLabel}
        </a>
      </div>
      <Search locale={locale} />
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-text-secondary hover:text-text" aria-label="Toggle menu" aria-expanded="false">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>
  <div id="mobile-menu" class="hidden lg:hidden border-t border-bg-border bg-bg px-4 pb-4 max-h-[70vh] overflow-y-auto">
    {groups.map((group, gi) => (
      <>
        {gi > 0 && <div class="border-t border-bg-border my-2"></div>}
        {navItems.filter(item => item.group === group).map((item) => (
          <a
            href={getLocalePath(locale, item.path)}
            class:list={[
              "block px-3 py-2 rounded-lg text-sm transition-colors",
              currentPath === item.path
                ? "bg-accent-purple/10 text-accent-purple"
                : "text-text-secondary hover:text-text",
            ]}
          >
            {t(locale, item.key)}
          </a>
        ))}
      </>
    ))}
    <div class="border-t border-bg-border my-2"></div>
    <a
      href={alternatePath}
      class="block px-3 py-2 rounded-lg text-sm transition-colors text-text-secondary hover:text-text border border-bg-border mt-1"
    >
      {alternateLinkLabel}
    </a>
  </div>
</nav>

<script>
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    const expanded = btn.getAttribute("aria-expanded") === "true";
    btn.setAttribute("aria-expanded", String(!expanded));
    menu?.classList.toggle("hidden");
  });
</script>
