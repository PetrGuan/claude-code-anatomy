---
import type { Locale } from "../../i18n/locales";
import { getLocalePath } from "../../i18n/locales";
import { t } from "../../i18n/translations";
import { getPage, contentPages } from "../../data/pages";

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;

const current = getPage(currentPath);
const related = (current?.related || [])
  .slice(0, 3)
  .map(path => getPage(path))
  .filter(Boolean);
---

{related.length > 0 && (
  <div class="mt-16">
    <h3 class="text-lg font-semibold mb-4">{t(locale, "common.relatedPages")}</h3>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {related.map((page) => page && (
        <a
          href={getLocalePath(locale, page.path)}
          class="group rounded-lg border border-bg-border p-4 hover:border-accent-purple/30 hover:bg-bg-card transition-colors"
        >
          <div class="flex items-center gap-2 mb-2">
            <span class="w-2 h-2 rounded-full" style={`background-color: ${page.color}`}></span>
            <span class="text-sm font-medium text-text group-hover:text-accent-purple transition-colors">{t(locale, page.navKey)}</span>
          </div>
          <p class="text-xs text-text-secondary line-clamp-2">{t(locale, page.descKey)}</p>
        </a>
      ))}
    </div>
  </div>
)}
