---
import Navbar from "../components/layout/Navbar.astro";
import Footer from "../components/layout/Footer.astro";
import "../styles/global.css";
import type { Locale } from "../i18n/locales";

interface Props {
  title: string;
  description?: string;
  locale?: Locale;
}

const { title, description, locale = "en" } = Astro.props;
const defaultDesc = locale === "zh"
  ? "深入浅出分析 Claude Code 源码架构"
  : "An in-depth visual analysis of Claude Code's source architecture";
const metaDesc = description ?? defaultDesc;
---

<!doctype html>
<html lang={locale === "zh" ? "zh-CN" : "en"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDesc} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <title>{title} | Claude Code Anatomy</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`${title} | Claude Code Anatomy`} />
    <meta property="og:description" content={metaDesc} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Claude Code Anatomy" />
    <meta property="og:locale" content={locale === "zh" ? "zh_CN" : "en_US"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${title} | Claude Code Anatomy`} />
    <meta name="twitter:description" content={metaDesc} />
  </head>
  <body class="min-h-screen">
    <Navbar locale={locale} />
    <main class="pt-16">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
